rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fungsi bantuan
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUserOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Asumsi ada custom claims atau field 'role' di token
      return request.auth.token.role == 'admin';
    }

    function isDoctor() {
      return request.auth.token.role == 'dokter';
    }

    // 1. Users Collection
    match /users/{userId} {
      // User bisa baca/tulis profil mereka sendiri. Admin bisa semuanya.
      allow read, update: if isAuthenticated() && (isUserOwner(userId) || isAdmin());
      // Hanya Admin yang bisa delete user
      allow delete: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && isUserOwner(userId);
    }

    // 2. Queues Collection (Realtime)
    match /queues/{queueId} {
      // Semua user authenticated bisa membaca antrian (untuk dashboard antrian realtime)
      allow read: if isAuthenticated();
      // Pasien hanya bisa membuat antrian dengan patientId miliknya
      allow create: if isAuthenticated() && (request.resource.data.patientId == request.auth.uid || isAdmin() || isDoctor());
      // Hanya dokter atau admin yang bisa memproses/menyelesaikan antrian
      allow update: if isAuthenticated() && (isDoctor() || isAdmin() || request.resource.data.patientId == request.auth.uid);
      // Delete hanya admin
      allow delete: if isAuthenticated() && isAdmin();
    }

    // 3. Medical History Collection
    match /medical_history/{historyId} {
      // Pasien hanya bisa melihat riwayatnya sendiri. Dokter bisa melihat semua.
      allow read: if isAuthenticated() && (resource.data.patientId == request.auth.uid || isDoctor() || isAdmin());
      // Hanya dokter dan admin yang bisa menulis rekam medis
      allow write: if isAuthenticated() && (isDoctor() || isAdmin());
    }
  }
}
